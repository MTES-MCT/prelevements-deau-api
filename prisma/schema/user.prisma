enum UserRole {
  DECLARANT
  INSTRUCTOR
  ADMIN
}

model User {
  id    String   @id @default(uuid()) @db.Uuid
  email String?  @unique @db.Citext
  role  UserRole

  firstName String?
  lastName  String?

  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  deletedAt                 DateTime?
  lastLoginAt               DateTime?
  accountCreationMailSentAt DateTime?

  declarant  Declarant?  @relation("UserDeclarant")
  instructor Instructor? @relation("UserInstructor")

  authTokens    AuthToken[]
  sessionTokens SessionToken[]
  emailAliases  UserEmailAlias[]
}

model UserEmailAlias {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  email String @unique @db.Citext

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum DeclarantType {
  NATURAL_PERSON
  LEGAL_PERSON
}

enum DeclarantRole {
  PRELEVEUR
  COLLECTEUR
}

enum Civility {
  MR
  MRS
}

model Declarant {
  userId String @id @db.Uuid
  user   User   @relation("UserDeclarant", fields: [userId], references: [id], onDelete: Cascade)

  declarations             Declaration[]                    @relation("DeclarationDeclarant")
  declarationsCreated      Declaration[]                    @relation("DeclarationCreatedByDeclarant")
  declarationTypes         DeclarantDeclarationType[]
  pointPrelevements        DeclarantPointPrelevement[]
  collecteurExploitations  DeclarantCollecteurExploitation[] @relation("CollecteurDeclarant")
  serviceAccountDeclarants ServiceAccountDeclarant[]
  serviceAccountTokens     ServiceAccountToken[]
  apiImports               ApiImport[]

  resourceDocuments ResourceDocument[]
  resourceRules     ResourceRule[]

  lastDeclarationAt      DateTime?
  lastReminderMailSentAt DateTime?

  declarantType DeclarantType @default(NATURAL_PERSON)
  declarantRole DeclarantRole @default(PRELEVEUR)

  jobTitle     String? @db.Text
  socialReason String? @db.Text

  civility Civility?

  addressLine1 String? @db.Text
  addressLine2 String? @db.Text
  poBox        String? @db.Text
  postalCode   String? @db.Text
  city         String? @db.Text
  siret        String? @db.Text

  phoneNumber String? @db.Text

  sourceId String? @db.Text

  @@unique([sourceId])
  @@index([declarantRole])
}

model Instructor {
  userId String @id @db.Uuid
  user   User   @relation("UserInstructor", fields: [userId], references: [id], onDelete: Cascade)

  phoneNumber String? @db.Text
  jobTitle    String? @db.Text

  instructorZones  InstructorZone[]
  instructedChunks Chunk[]

  sourceId String? @db.Text

  @@unique([sourceId])
}

model AuthToken {
  id    String @id @default(uuid()) @db.Uuid
  token String @unique

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model SessionToken {
  id    String @id @default(uuid()) @db.Uuid
  token String @unique

  role UserRole

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}
