enum DeclarantPointPrelevementStatus {
  EN_ACTIVITE
  NON_RENSEIGNE
  ABANDONNEE
  TERMINEE
}

enum UsageEau {
  INCONNU
  PAS_D_USAGE
  IRRIGATION
  AGRICULTURE_ELEVAGE
  AQUACULTURE
  INDUSTRIE
  AEP
  ENERGIE
  LOISIRS
  EMBOUTEILLAGE
  THERMALISME_THALASSO
  DEFENSE_INCENDIE
  REALIMENTATION_EAU
  CANAUX
  ETIAGE
  ENTRETIEN_VOIRIES
  ALIMENTATION_SOUTIEN_CANAL
  DOMESTIQUE
}

enum WaterBodyType {
  SURFACE
  SOUTERRAIN
  TRANSITION
}

model PointPrelevement {
  id String @id @default(uuid()) @db.Uuid

  name          String         @db.Text
  waterBodyType WaterBodyType?

  coordinates Unsupported("geometry(Point,4326)")?

  zones      PointPrelevementZone[]
  declarants DeclarantPointPrelevement[]
  compteurs  CompteurPointPrelevement[]

  chunks Chunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  otherNames            String?  @db.Text
  depth                 Float?
  isZre                 Boolean?
  isBiologicalReservoir Boolean?
  streamName            String?  @db.Text
  locationDescription   String?  @db.Text
  geometryPrecision     String?  @db.Text
  comment               String?  @db.Text
  internalComment       String?  @db.Text
  communeCode           String?  @db.Text
  communeName           String?  @db.Text

  sourceId String? @db.Text

  codeEUMasseDEau        String? @db.Text
  codePTP                String? @db.Text
  codeOPR                String? @db.Text
  codeBDLISA             String? @db.Text
  codeBSS                String? @db.Text
  codeAIOT               String? @db.Text
  codeBDCarthage         String? @db.Text
  codeBDTopage           String? @db.Text
  codeSISPEA             String? @db.Text
  codeBNPE               String? @db.Text
  codeMESO               String? @db.Text
  codeMEContinentalesBV  String? @db.Text

  @@unique([sourceId])
  @@unique([name])
  @@index([name])
  @@index([coordinates], type: Gist)
}

model PointPrelevementZone {
  id String @id @default(uuid()) @db.Uuid

  pointPrelevementId String           @db.Uuid
  pointPrelevement   PointPrelevement @relation(fields: [pointPrelevementId], references: [id], onDelete: Cascade)

  zoneId String @db.Uuid
  zone   Zone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([pointPrelevementId, zoneId])
  @@index([pointPrelevementId])
  @@index([zoneId])
}

model DeclarantPointPrelevement {
  id String @id @default(uuid()) @db.Uuid

  declarantUserId String    @db.Uuid
  declarant       Declarant @relation(fields: [declarantUserId], references: [userId], onDelete: Cascade)

  pointPrelevementId String           @db.Uuid
  pointPrelevement   PointPrelevement @relation(fields: [pointPrelevementId], references: [id], onDelete: Cascade)

  status    DeclarantPointPrelevementStatus @default(NON_RENSEIGNE)
  startDate DateTime?                       @db.Date
  endDate   DateTime?                       @db.Date
  usages    UsageEau[]                      @default([])

  abandonReason String? @db.Text
  comment       String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceId String? @db.Text

  mostRecentAvailableDate DateTime? @db.Date

  connectors DeclarantPointPrelevementConnector[]
  collecteurs DeclarantCollecteurExploitation[]
  documents  ResourceDocument[]
  rules      ResourceRuleExploitation[]

  @@unique([sourceId])
  @@unique([declarantUserId, pointPrelevementId])
  @@index([declarantUserId])
  @@index([pointPrelevementId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([usages], type: Gin)
}

model DeclarantCollecteurExploitation {
  id String @id @default(uuid()) @db.Uuid

  collecteurUserId String    @db.Uuid
  collecteur       Declarant @relation("CollecteurDeclarant", fields: [collecteurUserId], references: [userId], onDelete: Cascade)

  exploitationId String                    @db.Uuid
  exploitation   DeclarantPointPrelevement @relation(fields: [exploitationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([collecteurUserId, exploitationId])
  @@index([collecteurUserId])
  @@index([exploitationId])
}

model DeclarantPointPrelevementConnector {
  id String @id @default(uuid()) @db.Uuid

  declarantPointPrelevementId String                    @db.Uuid
  declarantPointPrelevement   DeclarantPointPrelevement @relation(fields: [declarantPointPrelevementId], references: [id], onDelete: Cascade)

  connectorType       String @db.Text
  connectorParameters Json   @default("{}") @db.Json
  rate                Float  @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([declarantPointPrelevementId])
  @@index([connectorType])
}
