enum ServiceAccountTokenType {
  ACCESS
  IMPERSONATION
}

model ServiceAccount {
  id String @id @default(uuid()) @db.Uuid

  name        String  @db.Text
  description String? @db.Text

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  credentials ServiceAccountCredential[]
  declarants  ServiceAccountDeclarant[]

  sourceId             String?               @unique @db.Text
  serviceAccountTokens ServiceAccountToken[]
}

model ServiceAccountCredential {
  id String @id @default(uuid()) @db.Uuid

  serviceAccountId String         @db.Uuid
  serviceAccount   ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  keyId      String @unique @db.Text
  secretHash String @db.Text

  name String? @db.Text

  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tokens ServiceAccountToken[]

  @@index([serviceAccountId])
  @@index([keyId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model ServiceAccountDeclarant {
  id String @id @default(uuid()) @db.Uuid

  serviceAccountId String         @db.Uuid
  serviceAccount   ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  declarantUserId String    @db.Uuid
  declarant       Declarant @relation(fields: [declarantUserId], references: [userId], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceAccountId, declarantUserId, startDate])
  @@index([serviceAccountId])
  @@index([declarantUserId])
  @@index([startDate])
  @@index([endDate])
  @@index([serviceAccountId, startDate, endDate])
}

model ServiceAccountToken {
  id String @id @default(uuid()) @db.Uuid

  serviceAccountId String         @db.Uuid
  serviceAccount   ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  credentialId String?                   @db.Uuid
  credential   ServiceAccountCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)

  declarantUserId String?    @db.Uuid
  declarant       Declarant? @relation(fields: [declarantUserId], references: [userId], onDelete: Cascade)

  tokenHash String                  @unique @db.Text
  type      ServiceAccountTokenType @default(ACCESS)

  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([serviceAccountId])
  @@index([credentialId])
  @@index([declarantUserId])
  @@index([type])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([serviceAccountId, type])
}
