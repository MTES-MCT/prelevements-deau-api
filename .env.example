# API config
PORT=5000

# PostgreSQL config
DATABASE_URL="postgresql://prelevements-deau:prelevements-deau@localhost:5432/prelevements-deau"

# Redis config (required for BullMQ workers - background job processing)
# Install Redis: brew install redis (macOS) or docker run -d -p 6379:6379 redis:alpine
REDIS_URL=redis://localhost:6379
REDIS_TLS_CA_FILE_PATH=

# BullBoard - Dashboard de monitoring des queues (optionnel)
# Accessible sur /admin/queues avec authentification Basic
# Si non défini, BullBoard est désactivé
BULLBOARD_PASSWORD=

# S3 config
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET_PREFIX=prelevements-deau-
S3_REGION=fr-par

# Email / SMTP config
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Prélèvements d'eau <noreply@example.com>"

# Auth config
API_URL=http://localhost:5000
FRONT_URL=http://localhost:3000
AUTH_TOKEN_TTL=3600
SESSION_TOKEN_TTL=2592000
NODE_ENV=development

# Sentry config (optionnel)
SENTRY_DSN=
SENTRY_ENV=
